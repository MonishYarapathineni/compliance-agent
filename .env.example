# Copy this file to .env and fill in real values. Never commit .env to git.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- LangSmith tracing (optional) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=compliance-agent

# --- Vector store ---
CHROMA_PERSIST_DIR=data/processed/chroma

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Document ingestion ---
RAW_DOCS_DIR=data/raw

PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=compliance-agent